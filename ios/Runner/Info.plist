		<array>
			<string>tel</string>
			<string>mailto</string>
			<string>sms</string>
			<string>http</string>
			<string>https</string>
			<string>comgooglemaps</string>
			<string>googlechromes</string>
			<string>fbapi</string>
			<string>fb-messenger-share-api</string>
		</array>
